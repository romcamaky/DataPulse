# DataPulse — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# dbt — Supabase direct connection (not the API URL)
# Note: SUPABASE_DB_HOST is the direct database host (db.xxx.supabase.co), NOT the API URL (xxx.supabase.co). Find it in Supabase → Settings → Database → Connection string.
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_DB_NAME=postgres
